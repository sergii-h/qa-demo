FROM node:22-alpine
WORKDIR /app
COPY demo-interface/package.json .
COPY demo-interface/index.html .
COPY demo-interface/vite.config.mts .
COPY demo-interface/tsconfig.json .
COPY demo-interface/src ./src
COPY demo-interface/public ./public
ARG BE_API_ARG
ENV VITE_BE_API=$BE_API_ARG
RUN npm install
EXPOSE 5173
CMD ["npx", "vite", "--host"]
