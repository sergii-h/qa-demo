{
  "request": {
    "method": "POST",
    "url": "/external/validate/task",
    "bodyPatterns" : [ {
      "matchesJsonPath" : {
        "expression": "$.description",
        "doesNotContain": "not valid"
      }
    } ]
  },

  "response": {
    "status": 200,
    "body": "true",
    "headers": {
      "Content-Type": "application/json"
    }
  }
}
