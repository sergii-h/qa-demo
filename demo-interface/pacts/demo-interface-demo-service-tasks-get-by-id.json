{
  "consumer": {
    "name": "demo-interface"
  },
  "interactions": [
    {
      "description": "a request for a task by id",
      "providerStates": [
        {
          "name": "a task exists"
        }
      ],
      "request": {
        "generators": {
          "path": {
            "expression": "/v1/tasks/${taskId}",
            "type": "ProviderState"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "path": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          }
        },
        "method": "GET",
        "path": "/v1/tasks/507f1f77bcf86cd799439011"
      },
      "response": {
        "body": {
          "createdDate": "2026-04-26T09:00:00.000Z",
          "description": "Document release tasks",
          "id": "507f1f77bcf86cd799439011",
          "priority": "MEDIUM",
          "status": "TODO",
          "title": "Prepare release notes",
          "updatedDate": "2026-04-26T09:00:00.000Z"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.createdDate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^\\d{4}-\\d{2}-\\d{2}T.*$"
                }
              ]
            },
            "$.description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[a-f0-9]{24}$"
                }
              ]
            },
            "$.priority": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.updatedDate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^\\d{4}-\\d{2}-\\d{2}T.*$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.4.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "demo-service-tasks-get-by-id"
  }
}