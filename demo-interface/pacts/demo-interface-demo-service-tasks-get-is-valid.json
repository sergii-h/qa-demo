{
  "consumer": {
    "name": "demo-interface"
  },
  "interactions": [
    {
      "description": "a request for task validation status",
      "providerStates": [
        {
          "name": "validation result is true for the task"
        }
      ],
      "request": {
        "generators": {
          "path": {
            "expression": "/v1/tasks/isValid/${taskId}",
            "type": "ProviderState"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "path": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          }
        },
        "method": "GET",
        "path": "/v1/tasks/isValid/507f1f77bcf86cd799439011"
      },
      "response": {
        "body": true,
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.4.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "demo-service-tasks-get-is-valid"
  }
}