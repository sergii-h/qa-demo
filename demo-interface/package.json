{
  "name": "@sgoldys/demo-interface",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@types/node": "^16.11.36",
    "@types/react": "^18.0.9",
    "@types/react-dom": "^18.0.5",
    "npm-run-all": "^4.1.5",
    "primeflex": "^3.2.0",
    "primeicons": "^5.0.0",
    "primereact": "^8.1.1",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-scripts": "5.0.1",
    "start-server-and-test": "1.14.0",
    "typescript": "^4.7.2",
    "web-vitals": "^2.1.4"
  },
  "overrides": {
    "react-refresh": "0.11.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:ci": "run-p \"cypress:run -- --spec {1}\" --",
    "start:for:ui:tests": "REACT_APP_UI_TESTS=true npm run start",
    "start:local:server": "npm run start:for:ui:tests",
    "cypress:run:local": "CYPRESS_BASE_URL=http://localhost:3000 start-server-and-test start:local:server 3000 'cypress:run'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "react-scripts test --watchAll=false --detectOpenHandles"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:storybook/recommended"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/preset-env": "^7.22.20",
    "@babel/preset-react": "^7.22.15",
    "@babel/preset-typescript": "^7.23.0",
    "@storybook/addon-essentials": "^7.4.5",
    "@storybook/addon-interactions": "^7.4.5",
    "@storybook/addon-links": "^7.4.5",
    "@storybook/addon-onboarding": "^1.0.8",
    "@storybook/blocks": "^7.4.5",
    "@storybook/preset-create-react-app": "^7.4.5",
    "@storybook/react": "^7.4.5",
    "@storybook/react-webpack5": "^7.4.5",
    "@storybook/testing-library": "^0.2.1",
    "babel-jest": "^29.7.0",
    "babel-plugin-named-exports-order": "^0.0.2",
    "cypress": "^9.7.0",
    "cypress-intercept-formdata": "^0.4.0",
    "eslint-plugin-storybook": "^0.6.14",
    "jest": "^27.5.1",
    "jest-environment-jsdom": "^29.7.0",
    "jest-extended": "^4.0.2",
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.1",
    "prop-types": "^15.8.1",
    "react-test-renderer": "^18.2.0",
    "storybook": "^7.4.5",
    "webpack": "^5.88.2"
  }
