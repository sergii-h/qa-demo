{
  "name": "@sgoldys/demo-interface",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "web-vitals": "^5.2.0"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "test:ui": "vitest --ui",
    "test": "vitest run --coverage",
    "test:pact": "rm -rf pacts && vitest run pact",
    "pact:broker:up": "docker compose -f ../docker/docker-compose-run-pact-broker.yml up -d",
    "pact:broker:down": "docker compose -f ../docker/docker-compose-run-pact-broker.yml down -v",
    "pact:publish": "docker run --rm --network=host -v \"$PWD/pacts:/pacts\" -e PACT_BROKER_BASE_URL=${PACT_BROKER_BASE_URL:-http://localhost:9292} pactfoundation/pact-cli:latest pact-broker publish /pacts --consumer-app-version ${PACT_CONSUMER_VERSION:-local-dev} --branch ${PACT_BRANCH:-local}",
    "pact:can-i-deploy": "docker run --rm --network=host -e PACT_BROKER_BASE_URL=${PACT_BROKER_BASE_URL:-http://localhost:9292} pactfoundation/pact-cli:latest pact-broker can-i-deploy --pacticipant demo-interface --version ${PACT_CONSUMER_VERSION:-local-dev} --to-environment ${PACT_ENVIRONMENT:-test}"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "happy-dom": "^20.8.9",
    "typescript": "^5.0.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
