{
  "name": "@sgoldys/demo-interface",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@types/node": "^18.19.68",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "npm-run-all": "^4.1.5",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "start-server-and-test": "2.0.9",
    "typescript": "^4.9.5",
    "web-vitals": "^4.2.4",
    "webpack": "^5.97.1"
  },
  "overrides": {
    "react-refresh": "0.11.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:ci": "run-p \"cypress:run -- --spec {1}\" --",
    "start:for:ui:tests": "REACT_APP_UI_TESTS=true npm run start",
    "start:local:server": "npm run start:for:ui:tests",
    "cypress:run:local": "CYPRESS_BASE_URL=http://localhost:3000 start-server-and-test start:local:server 3000 'cypress:run'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "react-scripts test --watchAll=false --detectOpenHandles"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:storybook/recommended"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "@jest/globals": "^29.7.0",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-links": "^8.4.7",
    "@storybook/addon-onboarding": "^1.0.11",
    "@storybook/blocks": "^8.4.7",
    "@storybook/preset-create-react-app": "^8.4.7",
    "@storybook/react": "^8.4.7",
    "@storybook/react-webpack5": "^8.4.7",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "babel-plugin-named-exports-order": "^0.0.2",
    "cypress": "^13.17.0",
    "cypress-intercept-formdata": "^0.6.0",
    "eslint-plugin-storybook": "^0.11.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-extended": "^4.0.2",
