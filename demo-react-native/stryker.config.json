{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "plugins": ["@stryker-mutator/jest-runner"],
  "testRunner": "jest",
  "reporters": ["html", "clear-text", "progress"],
  "ignorePatterns": ["coverage/**", "pacts/**", ".stryker-tmp/**", "node_modules/**"],
  "timeoutMS": 30000,
  "concurrency": 4,
  "jest": {
    "projectType": "custom",
    "configFile": "jest.stryker.config.js",
    "enableFindRelatedTests": false
  },
  "mutate": [
    "src/hooks/**/*.ts",
    "src/data/remote/**/*.ts",
    "src/i18n/errorMessages.ts",
    "src/i18n/taskLabels.ts",
    "src/repository/**/*.ts",
    "!**/*.spec.ts",
    "!**/*.spec.tsx"
  ],
  "mutator": {
    "excludedMutations": ["StringLiteral"]
  },
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": null
  }
}
