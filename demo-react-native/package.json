{
  "name": "demo-react-native",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:stryker": "stryker run",
    "test:pact": "rm -rf pacts && vitest run --config vitest.pact.config.mts",
    "pact:publish": "docker run --rm --network=host -v \"$PWD/pacts:/pacts\" -e PACT_BROKER_BASE_URL=${PACT_BROKER_BASE_URL:-http://localhost:9292} pactfoundation/pact-cli:latest pact-broker publish /pacts --consumer-app-version ${PACT_CONSUMER_VERSION:-local-dev} --branch ${PACT_BRANCH:-local}"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "expo": "~53.0.9",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.6",
    "expo-font": "~13.3.2",
    "expo-localization": "~16.1.5",
    "expo-status-bar": "~2.2.3",
    "i18next": "^26.0.3",
    "jest": "~29.7.0",
    "jest-expo": "~53.0.0",
    "react": "19.0.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-paper": "^5.14.1",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-test-renderer": "19.0.0"
  },
  "overrides": {
    "qs": "6.15.2",
    "uuid": "11.1.1",
    "postcss": "8.5.15",
    "js-yaml": "4.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@pact-foundation/pact": "^16.3.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.0.10",
    "@types/react-test-renderer": "^19.1.0",
    "typescript": "~5.8.3",
    "vitest": "^4.0.0"
  }
}
