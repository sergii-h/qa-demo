{
  "consumer": {
    "name": "demo-react-native"
  },
  "interactions": [
    {
      "description": "a request for all tasks",
      "providerStates": [
        {
          "name": "tasks exist"
        }
      ],
      "request": {
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "GET",
        "path": "/v1/tasks"
      },
      "response": {
        "body": [
          {
            "createdDate": "2026-04-26T09:00:00.000Z",
            "description": "Document release tasks",
            "id": "507f1f77bcf86cd799439011",
            "priority": "MEDIUM",
            "status": "TODO",
            "title": "Prepare release notes",
            "updatedDate": "2026-04-26T09:00:00.000Z"
          }
        ],
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$[*].createdDate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^\\d{4}-\\d{2}-\\d{2}T.*$"
                }
              ]
            },
            "$[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[a-f0-9]{24}$"
                }
              ]
            },
            "$[*].priority": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$[*].updatedDate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^\\d{4}-\\d{2}-\\d{2}T.*$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "demo-service-tasks-get-all"
  }
}