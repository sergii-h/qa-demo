{
  "consumer": {
    "name": "demo-react-native"
  },
  "interactions": [
    {
      "description": "a task update request with duplicate title",
      "providerStates": [
        {
          "name": "another task has the requested title"
        }
      ],
      "request": {
        "body": {
          "description": "Document release tasks in detail",
          "priority": "HIGH",
          "status": "IN_PROGRESS",
          "title": "Prepare release notes - updated"
        },
        "generators": {
          "body": {
            "$.title": {
              "expression": "${updatedTitle}",
              "type": "ProviderState"
            }
          },
          "path": {
            "expression": "/v1/tasks/${taskId}",
            "type": "ProviderState"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "path": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          }
        },
        "method": "PUT",
        "path": "/v1/tasks/507f1f77bcf86cd799439011"
      },
      "response": {
        "body": {
          "message": "Task with title 'Prepare release notes - updated' already exists"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^Task with title '.*' already exists$"
                }
              ]
            }
          }
        },
        "status": 409
      }
    },
    {
      "description": "a valid task update request",
      "providerStates": [
        {
          "name": "a task exists to update and title is unique"
        }
      ],
      "request": {
        "body": {
          "description": "Document release tasks in detail",
          "priority": "HIGH",
          "status": "IN_PROGRESS",
          "title": "Prepare release notes - updated"
        },
        "generators": {
          "body": {
            "$.title": {
              "expression": "${updatedTitle}",
              "type": "ProviderState"
            }
          },
          "path": {
            "expression": "/v1/tasks/${taskId}",
            "type": "ProviderState"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "path": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          }
        },
        "method": "PUT",
        "path": "/v1/tasks/507f1f77bcf86cd799439011"
      },
      "response": {
        "body": {
          "createdDate": "2026-04-26T09:00:00.000Z",
          "description": "Document release tasks in detail",
          "id": "507f1f77bcf86cd799439011",
          "priority": "HIGH",
          "status": "IN_PROGRESS",
          "title": "Prepare release notes - updated",
          "updatedDate": "2026-04-26T10:30:00.000Z"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.createdDate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^\\d{4}-\\d{2}-\\d{2}T.*$"
                }
              ]
            },
            "$.description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[a-f0-9]{24}$"
                }
              ]
            },
            "$.priority": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.updatedDate": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^\\d{4}-\\d{2}-\\d{2}T.*$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "demo-service-tasks-update"
  }
}